# Copy this to .env and fill in your values

# Knowledge base path (local folder or s3://bucket/prefix)
GHOST_KB_PATH=./kb

# LLM model (LiteLLM format: provider/model)
GHOST_LLM_MODEL=openai/gpt-4o-mini

# Embedding model
GHOST_EMBEDDING_MODEL=openai/text-embedding-3-small
GHOST_EMBEDDING_DIM=1536

# API keys — LiteLLM picks these up automatically
OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# DEEPSEEK_API_KEY=...

# Optional tuning
GHOST_CHUNK_SIZE=512
GHOST_CHUNK_OVERLAP=64
GHOST_TOP_K=6
GHOST_WORKER_CONCURRENCY=4
